/* ==============================================
   COBOLD POS — Shared Stylesheet
   Breakpoints:
     Mobile  : < 640px
     Tablet  : 640px – 1024px
     Desktop : > 1024px
   ============================================== */

/* ── RESET & BASE ── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg-color:  #0d0d0d;
  --card-bg:   #161616;
  --accent:    #b08968;
  --accent-h:  #c49a7a;
  --text-main: #e0e0e0;
  --text-dim:  #888;
  --border:    #222;
  --red:       #ff5f5f;
  --green:     #22c55e;
  --yellow:    #f59e0b;
  --sidebar-w: 240px;
  --bottomnav: 64px;
}

html { -webkit-text-size-adjust: 100%; }

body {
  font-family: 'Inter', sans-serif;
  background-color: var(--bg-color);
  color: var(--text-main);
  display: flex;
  min-height: 100vh;
  min-height: 100dvh;
}

/* ── LOADING OVERLAY ── */
#loadingOverlay {
  position: fixed; inset: 0;
  background: var(--bg-color);
  display: flex; align-items: center; justify-content: center;
  z-index: 9999;
  font-size: 20px; font-weight: 600;
  color: var(--accent); letter-spacing: 3px;
}

/* ══════════════════════════════════════════════
   SIDEBAR — Desktop
   ══════════════════════════════════════════════ */
.sidebar {
  width: var(--sidebar-w);
  background-color: var(--card-bg);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  padding: 30px 20px;
  flex-shrink: 0;
  position: sticky;
  top: 0;
  height: 100vh;
  overflow-y: auto;
}

.logo {
  font-weight: 600;
  font-size: 20px;
  color: var(--accent);
  text-transform: uppercase;
  letter-spacing: 2px;
  margin-bottom: 40px;
  text-align: center;
  flex-shrink: 0;
}

.nav-menu { flex-grow: 1; }

.nav-section-label {
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: #444;
  padding: 0 15px;
  margin: 16px 0 6px;
  display: block;
}

.nav-item {
  display: flex;
  align-items: center;
  padding: 12px 15px;
  color: var(--text-dim);
  text-decoration: none;
  border-radius: 8px;
  margin-bottom: 4px;
  transition: 0.2s;
  font-size: 14px;
  white-space: nowrap;
}
.nav-item i { margin-right: 12px; width: 20px; text-align: center; flex-shrink: 0; }
.nav-item:hover,
.nav-item.active { background-color: #222; color: var(--accent); }

.btn-logout {
  background: none;
  border: 1px solid #444;
  color: var(--red);
  padding: 10px;
  border-radius: 8px;
  cursor: pointer;
  font-weight: 600;
  transition: 0.3s;
  width: 100%;
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  flex-shrink: 0;
}
.btn-logout:hover { background: var(--red); color: white; }

/* ══════════════════════════════════════════════
   BOTTOM NAV — Mobile only (hidden on desktop)
   ══════════════════════════════════════════════ */
.bottom-nav {
  display: none;
  position: fixed;
  bottom: 0; left: 0; right: 0;
  height: var(--bottomnav);
  background: var(--card-bg);
  border-top: 1px solid var(--border);
  z-index: 500;
  justify-content: space-around;
  align-items: center;
  padding: 0 8px;
  padding-bottom: env(safe-area-inset-bottom);
}

.bn-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 3px;
  flex: 1;
  padding: 8px 4px;
  color: var(--text-dim);
  text-decoration: none;
  font-size: 10px;
  border-radius: 8px;
  transition: 0.2s;
  cursor: pointer;
  background: none;
  border: none;
  font-family: 'Inter', sans-serif;
}
.bn-item i { font-size: 18px; }
.bn-item:hover,
.bn-item.active { color: var(--accent); }
.bn-item.admin-only { display: none; }

/* ══════════════════════════════════════════════
   MAIN CONTENT
   ══════════════════════════════════════════════ */
.main-content {
  flex-grow: 1;
  padding: 40px;
  overflow-y: auto;
  min-width: 0;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30px;
  flex-wrap: wrap;
  gap: 12px;
}
.header h1 { font-size: 24px; }
.header-sub { font-size: 14px; color: var(--text-dim); margin-top: 4px; }

/* ══════════════════════════════════════════════
   CARDS & TABLES
   ══════════════════════════════════════════════ */
.card {
  background-color: var(--card-bg);
  border-radius: 16px;
  padding: 20px;
  border: 1px solid var(--border);
  margin-bottom: 20px;
}
.card h2 { font-size: 18px; margin-bottom: 10px; }

.card-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
  flex-wrap: wrap;
  gap: 10px;
}

.table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; }

table { width: 100%; border-collapse: collapse; min-width: 500px; }
th {
  text-align: left;
  color: var(--text-dim);
  font-size: 13px;
  padding: 12px;
  border-bottom: 1px solid var(--border);
  font-weight: 400;
  white-space: nowrap;
}
td {
  padding: 14px 12px;
  font-size: 14px;
  border-bottom: 1px solid #1a1a1a;
  vertical-align: middle;
}
tr:last-child td { border-bottom: none; }
tbody tr:hover td { background: rgba(255,255,255,0.015); }

.empty-cell {
  text-align: center !important;
  color: var(--text-dim);
  padding: 36px !important;
  font-size: 14px;
}

/* ══════════════════════════════════════════════
   STATS GRID
   ══════════════════════════════════════════════ */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 16px;
  margin-bottom: 24px;
}
.stat-card {
  background-color: var(--card-bg);
  padding: 20px;
  border-radius: 16px;
  border: 1px solid var(--border);
}
.stat-card h3 {
  font-size: 11px;
  color: var(--text-dim);
  margin: 0 0 10px 0;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}
.stat-card .value { font-size: 26px; font-weight: 600; color: var(--accent); }
.stat-card .value-sub { font-size: 12px; color: var(--text-dim); margin-top: 4px; }

/* ══════════════════════════════════════════════
   BADGES
   ══════════════════════════════════════════════ */
.badge {
  display: inline-block;
  padding: 4px 8px;
  border-radius: 4px;
  font-size: 11px;
  font-weight: 600;
}
.badge-red    { background: rgba(255,95,95,0.2);    color: var(--red); }
.badge-green  { background: rgba(34,197,94,0.2);    color: var(--green); }
.badge-yellow { background: rgba(245,158,11,0.2);   color: var(--yellow); }
.badge-accent { background: rgba(176,137,104,0.2);  color: var(--accent); }

/* ══════════════════════════════════════════════
   BUTTONS
   ══════════════════════════════════════════════ */
.btn-primary {
  background: var(--accent);
  color: white;
  border: none;
  border-radius: 8px;
  padding: 10px 20px;
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  transition: 0.2s;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  white-space: nowrap;
}
.btn-primary:hover    { background: var(--accent-h); }
.btn-primary:disabled { opacity: 0.45; cursor: default; }

.btn-secondary {
  background: none;
  color: var(--text-dim);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 10px 20px;
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  cursor: pointer;
  transition: 0.2s;
  display: inline-flex;
  align-items: center;
  gap: 8px;
}
.btn-secondary:hover { border-color: var(--accent); color: var(--accent); }

.btn-sm {
  background: none;
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 5px 12px;
  font-size: 12px;
  color: var(--text-dim);
  cursor: pointer;
  font-family: 'Inter', sans-serif;
  transition: 0.2s;
  margin-right: 4px;
  white-space: nowrap;
}
.btn-sm:hover        { border-color: var(--accent); color: var(--accent); }
.btn-sm.danger:hover { border-color: var(--red);    color: var(--red); }

/* ══════════════════════════════════════════════
   FORMS
   ══════════════════════════════════════════════ */
.form-group { margin-bottom: 16px; }
.form-group label {
  display: block;
  font-size: 12px;
  color: var(--text-dim);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 7px;
}
.form-group input,
.form-group select,
.form-group textarea {
  width: 100%;
  background: #0d0d0d;
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 10px 14px;
  color: var(--text-main);
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  outline: none;
  transition: border-color 0.2s;
  -webkit-appearance: none;
}
.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus { border-color: var(--accent); }
.form-group select option { background: #161616; }

.form-row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }

/* ══════════════════════════════════════════════
   TABS
   ══════════════════════════════════════════════ */
.tabs {
  display: flex;
  gap: 4px;
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 4px;
  width: fit-content;
  margin-bottom: 20px;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}
.tab-btn {
  padding: 8px 18px;
  border-radius: 7px;
  border: none;
  background: none;
  color: var(--text-dim);
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  cursor: pointer;
  transition: 0.2s;
  white-space: nowrap;
}
.tab-btn.active { background: #222; color: var(--accent); font-weight: 600; }

/* ══════════════════════════════════════════════
   MODAL
   ══════════════════════════════════════════════ */
.modal-overlay {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.8);
  display: flex; align-items: center; justify-content: center;
  z-index: 200;
  opacity: 0; pointer-events: none; transition: opacity 0.2s;
  padding: 16px;
}
.modal-overlay.show { opacity: 1; pointer-events: all; }

.modal {
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 28px;
  width: 100%;
  max-width: 480px;
  max-height: 90dvh;
  overflow-y: auto;
  transform: scale(0.95);
  transition: transform 0.2s;
}
.modal-overlay.show .modal { transform: scale(1); }
.modal h2 { font-size: 18px; margin-bottom: 20px; }

.modal-footer {
  display: flex;
  gap: 10px;
  margin-top: 22px;
}
.btn-modal-cancel {
  flex: 1; padding: 11px;
  background: none; border: 1px solid var(--border);
  border-radius: 8px; color: var(--text-dim);
  font-family: 'Inter', sans-serif; font-size: 14px; cursor: pointer; transition: 0.2s;
}
.btn-modal-cancel:hover { border-color: var(--text-dim); color: var(--text-main); }
.btn-modal-confirm {
  flex: 2; padding: 11px;
  background: var(--accent); border: none;
  border-radius: 8px; color: white;
  font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 600; cursor: pointer; transition: 0.2s;
}
.btn-modal-confirm:hover    { background: var(--accent-h); }
.btn-modal-confirm:disabled { opacity: 0.45; cursor: default; }

/* ══════════════════════════════════════════════
   TOAST
   ══════════════════════════════════════════════ */
.toast {
  position: fixed; bottom: 24px; left: 50%;
  transform: translateX(-50%) translateY(80px);
  background: var(--card-bg); border: 1px solid var(--border);
  border-radius: 9px; padding: 12px 24px;
  font-size: 14px; z-index: 999;
  transition: transform 0.3s ease;
  white-space: nowrap;
  pointer-events: none;
}
.toast.show { transform: translateX(-50%) translateY(0); }
.toast.success { border-color: rgba(34,197,94,0.5);  color: var(--green); }
.toast.error   { border-color: rgba(255,95,95,0.5);  color: var(--red); }

/* Alert banner */
.alert-low {
  background: rgba(255,95,95,0.06);
  border: 1px solid rgba(255,95,95,0.2);
  border-radius: 12px;
  padding: 14px 18px;
  margin-bottom: 20px;
  display: none;
  align-items: flex-start;
  gap: 12px;
}
.alert-low.show { display: flex; }
.alert-low i { color: var(--red); margin-top: 2px; flex-shrink: 0; }
.alert-low-title { font-size: 13px; font-weight: 600; color: var(--red); margin-bottom: 4px; }
.alert-low-body  { font-size: 12px; color: #cc8888; line-height: 1.8; }

/* Search input */
.search-input {
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 9px 14px;
  color: var(--text-main);
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  outline: none;
  transition: border-color 0.2s;
  -webkit-appearance: none;
}
.search-input:focus { border-color: var(--accent); }

.filter-select {
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 9px 12px;
  color: var(--text-main);
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  outline: none;
  cursor: pointer;
  -webkit-appearance: none;
}
.filter-select option { background: #161616; }

/* Avail toggle */
.avail-toggle {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  cursor: pointer;
}
.avail-toggle input { accent-color: var(--accent); cursor: pointer; }

/* ══════════════════════════════════════════════
   TABLET  640px – 1024px
   ══════════════════════════════════════════════ */
@media (max-width: 1024px) {
  :root { --sidebar-w: 64px; }

  .sidebar { padding: 20px 10px; align-items: center; overflow: visible; }
  .logo { font-size: 13px; letter-spacing: 1px; margin-bottom: 28px; }
  .nav-section-label { display: none; }
  .nav-item { padding: 12px; justify-content: center; margin-bottom: 6px; }
  .nav-item i { margin-right: 0; font-size: 18px; }
  .nav-item span { display: none; }
  .btn-logout { padding: 10px; font-size: 0; }
  .btn-logout::before { content: '\f2f5'; font-family: 'Font Awesome 6 Free'; font-weight: 900; font-size: 16px; }

  .main-content { padding: 24px 20px; }
  .stats-grid { grid-template-columns: 1fr 1fr; gap: 12px; }
  .stat-card .value { font-size: 22px; }
}

/* ══════════════════════════════════════════════
   MOBILE  < 640px
   ══════════════════════════════════════════════ */
@media (max-width: 640px) {
  body { flex-direction: column; padding-bottom: var(--bottomnav); }

  /* Hide sidebar, show bottom nav */
  .sidebar { display: none; }
  .bottom-nav { display: flex; }

  .main-content { padding: 20px 16px; }

  .header h1 { font-size: 20px; }
  .header { margin-bottom: 20px; }

  .stats-grid {
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-bottom: 16px;
  }
  .stat-card { padding: 16px; }
  .stat-card h3 { font-size: 10px; }
  .stat-card .value { font-size: 20px; }

  .card { padding: 16px; border-radius: 12px; }
  .card h2 { font-size: 16px; }

  .card-head { flex-direction: column; align-items: flex-start; }
  .card-head .btn-primary { width: 100%; justify-content: center; }

  .form-row-2 { grid-template-columns: 1fr; gap: 0; }

  table { min-width: 420px; }
  th, td { padding: 10px 8px; font-size: 13px; }

  .modal { padding: 20px; border-radius: 14px; }
  .modal h2 { font-size: 16px; margin-bottom: 16px; }

  .tabs { width: 100%; }
  .tab-btn { flex: 1; text-align: center; padding: 8px 10px; font-size: 13px; }

  .toast { width: calc(100% - 32px); text-align: center; white-space: normal; bottom: calc(var(--bottomnav) + 12px); }

  .search-input { width: 100%; }
  .filter-select { flex: 1; }

  .btn-primary { font-size: 13px; padding: 10px 16px; }
  .btn-sm { padding: 5px 8px; font-size: 11px; }
}
