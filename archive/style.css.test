body {
    transition: 0.5s;
    font-family: sans-serif;
    margin: 0;
    display: flex;
    flex-direction: column;
    height: 100vh;
}

body.dark-mode {
    background-color: #1a1a1a;
    color: white;
}

nav {
    display: flex;
    justify-content: space-between;
    padding: 20px 10%;
    background: #eee;
}

body.dark-mode nav {
    background: #333;
}

.hero {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
}

button {
    padding: 10px 20px;
    cursor: pointer;
    border-radius: 5px;
    border: none;
    background: #2563eb;
    color: white;
}
