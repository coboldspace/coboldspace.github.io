<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover"/>
  <title>Cobold POS — Transaksi</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>
  <link rel="stylesheet" href="pos.css"/>
  <style>
    /* ── POS LAYOUT ── */
    .pos-wrap {
      display: flex;
      flex: 1;
      overflow: hidden;
      min-height: 0;
    }
    .menu-panel {
      flex: 1;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      min-width: 0;
      min-height: 0;
    }
    .menu-toolbar {
      padding: 16px 20px;
      border-bottom: 1px solid var(--border);
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      align-items: center;
      flex-shrink: 0;
    }
    .cat-pills { display: flex; gap: 6px; flex-wrap: wrap; }
    .cat-pill {
      padding: 6px 14px;
      border-radius: 20px;
      border: 1px solid var(--border);
      background: none;
      color: var(--text-dim);
      font-family: 'Inter', sans-serif;
      font-size: 12px;
      cursor: pointer;
      transition: 0.2s;
      white-space: nowrap;
    }
    .cat-pill:hover  { border-color: var(--accent); color: var(--accent); }
    .cat-pill.active { background: var(--accent); border-color: var(--accent); color: white; font-weight: 600; }

    .menu-grid {
      flex: 1;
      overflow-y: auto;
      padding: 16px 20px;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
      gap: 12px;
      align-content: start;
      min-height: 0;
    }
    .menu-grid::-webkit-scrollbar { width: 4px; }
    .menu-grid::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }

    .menu-card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 16px;
      cursor: pointer;
      transition: 0.2s;
      user-select: none;
    }
    .menu-card:hover  { border-color: var(--accent); transform: translateY(-2px); }
    .menu-card:active { transform: translateY(0); }
    .menu-card-cat    { font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--accent); margin-bottom: 6px; }
    .menu-card-name   { font-size: 14px; font-weight: 600; margin-bottom: 8px; line-height: 1.3; }
    .menu-card-price  { font-size: 14px; color: var(--accent); font-weight: 600; }
    .menu-card-stock  { font-size: 11px; color: var(--text-dim); margin-top: 4px; }
    .menu-card-stock.low { color: var(--red); }
    .menu-empty       { grid-column: 1/-1; text-align: center; padding: 48px; color: var(--text-dim); font-size: 14px; }

    .menu-card.disabled {
      opacity: 0.4;
      cursor: not-allowed;
      border-color: var(--border);
    }
    .menu-card.disabled:hover { transform: none; border-color: var(--border); }

    /* ORDER PANEL */
    .order-panel {
      width: 300px;
      border-left: 1px solid var(--border);
      background: var(--card-bg);
      display: flex;
      flex-direction: column;
      flex-shrink: 0;
      overflow: hidden;
      min-height: 0;
    }
    .order-head { padding: 16px 18px; border-bottom: 1px solid var(--border); flex-shrink: 0; }
    .order-head-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
    .order-head-top h2 { font-size: 16px; }
    .btn-clear { background: none; border: none; color: var(--text-dim); font-size: 12px; cursor: pointer; font-family: 'Inter', sans-serif; text-decoration: underline; padding: 0; transition: 0.2s; }
    .btn-clear:hover { color: var(--red); }
    .type-toggle { display: flex; gap: 6px; }
    .type-btn {
      flex: 1; padding: 8px;
      border-radius: 8px; border: 1px solid var(--border);
      background: none; color: var(--text-dim);
      font-family: 'Inter', sans-serif; font-size: 13px; cursor: pointer; transition: 0.2s;
    }
    .type-btn.active { background: #222; border-color: var(--accent); color: var(--text-main); }

    .table-wrap-input { margin-top: 10px; display: none; }
    .table-wrap-input.show { display: block; }
    .table-wrap-input label { font-size: 11px; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.08em; display: block; margin-bottom: 6px; }
    .table-wrap-input input {
      width: 100%; background: var(--bg-color);
      border: 1px solid var(--border); border-radius: 8px;
      padding: 8px 12px; color: var(--text-main);
      font-family: 'Inter', sans-serif; font-size: 14px; outline: none;
    }
    .table-wrap-input input:focus { border-color: var(--accent); }

    .order-items { flex: 1; overflow-y: auto; padding: 12px 18px; min-height: 0; }
    .order-items::-webkit-scrollbar { width: 3px; }
    .order-items::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
    .order-empty { text-align: center; color: var(--text-dim); font-size: 13px; padding: 36px 0; font-style: italic; }

    .order-item { display: flex; align-items: center; gap: 10px; padding: 10px 0; border-bottom: 1px solid var(--border); }
    .order-item:last-child { border-bottom: none; }
    .oi-info  { flex: 1; min-width: 0; }
    .oi-name  { font-size: 13px; font-weight: 600; margin-bottom: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .oi-price { font-size: 12px; color: var(--text-dim); }
    .qty-ctrl { display: flex; align-items: center; gap: 6px; flex-shrink: 0; }
    .qty-btn  {
      width: 26px; height: 26px; border-radius: 6px;
      border: 1px solid var(--border); background: #222;
      color: var(--text-main); font-size: 15px; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: 0.2s; line-height: 1;
    }
    .qty-btn:hover { border-color: var(--accent); color: var(--accent); }
    .qty-num { font-size: 14px; font-weight: 600; min-width: 18px; text-align: center; }

    .order-notes { padding: 10px 18px; border-top: 1px solid var(--border); flex-shrink: 0; }
    .order-notes label { font-size: 11px; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.08em; display: block; margin-bottom: 6px; }
    .order-notes textarea {
      width: 100%; background: var(--bg-color);
      border: 1px solid var(--border); border-radius: 8px;
      padding: 8px 12px; color: var(--text-main);
      font-family: 'Inter', sans-serif; font-size: 13px;
      outline: none; resize: none; height: 52px;
    }
    .order-notes textarea:focus { border-color: var(--accent); }

    .order-foot { padding: 14px 18px; border-top: 1px solid var(--border); flex-shrink: 0; }
    .total-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
    .total-label { font-size: 12px; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.08em; }
    .total-value { font-size: 22px; font-weight: 600; color: var(--accent); }
    .btn-pay {
      width: 100%; padding: 13px;
      background: var(--accent); color: white; border: none;
      border-radius: 10px; font-family: 'Inter', sans-serif;
      font-size: 15px; font-weight: 600; cursor: pointer; transition: 0.2s;
    }
    .btn-pay:hover    { background: var(--accent-h); }
    .btn-pay:disabled { opacity: 0.4; cursor: default; }

    /* Confirm modal items */
    .confirm-item { display: flex; justify-content: space-between; font-size: 13px; padding: 5px 0; color: var(--text-dim); border-bottom: 1px solid #1a1a1a; }
    .confirm-item:last-of-type { border-bottom: none; }
    .confirm-item span:last-child { color: var(--text-main); }
    .confirm-total { display: flex; justify-content: space-between; font-size: 15px; font-weight: 600; margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--border); }
    .confirm-total span:last-child { color: var(--accent); }

    /* ── MOBILE: TAB SWITCH LAYOUT ── */
    @media (max-width: 640px) {
      .pos-wrap { 
        flex-direction: column; 
        flex: 1 1 auto;
        min-height: 0;
        overflow: hidden;
        position: relative;
      }
      .pos-tabs {
        display: flex;
        border-bottom: 1px solid var(--border);
        background: var(--card-bg);
        flex-shrink: 0;
        z-index: 10;
      }
      .pos-tab {
        flex: 1;
        padding: 12px;
        text-align: center;
        font-size: 13px;
        font-weight: 600;
        color: var(--text-dim);
        background: none;
        border: none;
        border-bottom: 2px solid transparent;
        cursor: pointer;
        font-family: 'Inter', sans-serif;
        transition: 0.2s;
      }
      .pos-tab.active {
        color: var(--accent);
        border-bottom-color: var(--accent);
      }
      .pos-tab .tab-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 18px;
        height: 18px;
        padding: 0 5px;
        background: var(--accent);
        color: white;
        border-radius: 9px;
        font-size: 10px;
        margin-left: 6px;
        font-weight: 600;
      }
      .menu-panel { 
        flex: 1;
        min-height: 0;
        display: none;
      }
      .menu-panel.active { display: flex; }
      .menu-toolbar { padding: 12px 14px; }
      .menu-grid { 
        padding: 12px 14px; 
        grid-template-columns: repeat(2, 1fr); 
        gap: 10px; 
      }
      .menu-card { padding: 14px; }
      .menu-card-name { font-size: 13px; }
      .order-panel {
        width: 100%;
        border-left: none;
        border-top: none;
        display: none;
        flex: 1;
        min-height: 0;
        padding-bottom: calc(var(--bn-h) + var(--bn-bubble)/2 + 20px + env(safe-area-inset-bottom, 16px));
      }
      .order-panel.active { display: flex; }
      .order-items { 
        flex: 1; 
        padding: 12px 14px; 
        overflow-y: auto;
      }
      .order-notes { display: none; }
      .order-head { padding: 12px 14px; }
      .order-foot { padding: 12px 14px; }
      .cart-float {
        position: fixed;
        bottom: calc(var(--bn-total) + 8px);
        left: 16px;
        right: 16px;
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 10px 16px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        z-index: 700;
        box-shadow: 0 4px 20px rgba(0,0,0,0.5);
      }
      .cart-float.hidden { display: none; }
      .cart-float-total { font-size: 14px; color: var(--text-dim); }
      .cart-float-total span { color: var(--accent); font-weight: 600; font-size: 18px; }
      .cart-float-btn {
        background: var(--accent);
        color: white;
        border: none;
        border-radius: 8px;
        padding: 8px 16px;
        font-family: 'Inter', sans-serif;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
      }
    }
    @media (max-width: 1024px) and (min-width: 641px) {
      .order-panel { width: 260px; }
      .menu-grid { grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); }
      .pos-tabs { display: none; }
      .cart-float { display: none !important; }
    }
    @media (min-width: 641px) {
      .pos-tabs { display: none; }
      .cart-float { display: none !important; }
    }
  </style>

</head>
<body>

<div id="loadingOverlay">COBOLD POS</div>

<!-- SIDEBAR -->
<div class="sidebar">
  <div class="logo">Cobold POS</div>
  <nav class="nav-menu">
    <a href="dashboard.html" class="nav-item"><i class="fa-solid fa-house"></i><span>Dashboard</span></a>
    <a href="kasir.html"     class="nav-item active"><i class="fa-solid fa-cash-register"></i><span>Transaksi</span></a>
    <a href="admin.html"     class="nav-item admin-only"><i class="fa-solid fa-mug-hot"></i><span>Menu</span></a>
    <a href="inventory.html" class="nav-item admin-only"><i class="fa-solid fa-box"></i><span>Inventori</span></a>
    <a href="roasting.html"  class="nav-item admin-only"><i class="fa-solid fa-fire"></i><span>Roasting</span></a>
    <a href="hpp.html"       class="nav-item admin-only"><i class="fa-solid fa-calculator"></i><span>HPP</span></a>
  </nav>
  <button class="btn-logout" id="btnLogout">LOGOUT</button>
</div>

<!-- BOTTOM NAV -->
<nav class="bottom-nav">
  <div class="bn-bar">
    <a href="dashboard.html" class="bn-item"><i class="fa-solid fa-house"></i><span>Dashboard</span></a>
    <a href="kasir.html"     class="bn-item active"><i class="fa-solid fa-cash-register"></i><span>Transaksi</span></a>
    <a href="admin.html"     class="bn-item admin-only"><i class="fa-solid fa-mug-hot"></i><span>Menu</span></a>
    <a href="inventory.html" class="bn-item admin-only"><i class="fa-solid fa-box"></i><span>Inventori</span></a>
    <a href="roasting.html"  class="bn-item admin-only"><i class="fa-solid fa-fire"></i><span>Roasting</span></a>
    <a href="hpp.html"       class="bn-item admin-only"><i class="fa-solid fa-calculator"></i><span>HPP</span></a>
  </div>
</nav>

<!-- MOBILE TAB SWITCHER -->
<div class="pos-tabs" id="posTabs">
  <button class="pos-tab active" onclick="switchTab('menu')" id="tabMenu">
    📋 Menu
  </button>
  <button class="pos-tab" onclick="switchTab('order')" id="tabOrder">
    🛒 Pesanan <span class="tab-badge" id="tabBadge" style="display:none">0</span>
  </button>
</div>

<!-- FLOATING CART (mobile only) -->
<div class="cart-float hidden" id="cartFloat">
  <div class="cart-float-total">Total: <span id="cartFloatTotal">Rp 0</span></div>
  <button class="cart-float-btn" onclick="switchTab('order')">Lihat Pesanan</button>
</div>

<!-- POS -->
<div class="pos-wrap">
  <div class="menu-panel active" id="menuPanel">
    <div class="menu-toolbar">
      <input class="search-input" type="text" id="searchInput" placeholder="Cari menu..." oninput="renderMenu()" style="width:160px"/>
      <div class="cat-pills" id="catPills"></div>
    </div>
    <div class="menu-grid" id="menuGrid"><div class="menu-empty">Memuat menu...</div></div>
  </div>

  <div class="order-panel" id="orderPanel">
    <div class="order-head">
      <div class="order-head-top">
        <h2>Pesanan</h2>
        <button class="btn-clear" onclick="clearCart()">Hapus semua</button>
      </div>
      <div class="type-toggle">
        <button class="type-btn active" id="btnDineIn"   onclick="setType('dine-in')">🍽 Dine-in</button>
        <button class="type-btn"        id="btnTakeaway" onclick="setType('takeaway')">🥡 Takeaway</button>
      </div>
      <div class="table-wrap-input show" id="tableWrap">
        <label>Nomor Meja</label>
        <input type="text" id="tableNo" placeholder="contoh: 5"/>
      </div>
    </div>
    <div class="order-items" id="orderItems">
      <div class="order-empty">Pilih menu untuk memulai.</div>
    </div>
    <div class="order-notes">
      <label>Catatan</label>
      <textarea id="orderNotes" placeholder="Less sugar, extra hot..."></textarea>
    </div>
    <div class="order-foot">
      <div class="total-row">
        <span class="total-label">Total</span>
        <span class="total-value" id="totalValue">Rp 0</span>
      </div>
      <button class="btn-pay" id="btnPay" onclick="openConfirm()" disabled>Proses Pesanan</button>
    </div>
  </div>
</div>

<!-- CONFIRM MODAL -->
<div class="modal-overlay" id="confirmModal">
  <div class="modal">
    <h2>Konfirmasi Pesanan</h2>
    <p style="font-size:13px;color:var(--text-dim);margin-bottom:16px">Periksa kembali sebelum diproses.</p>
    <div id="confirmItems"></div>
    <div class="modal-footer">
      <button class="btn-modal-cancel"  onclick="closeConfirm()">Batal</button>
      <button class="btn-modal-confirm" id="btnConfirm" onclick="submitOrder()">Konfirmasi</button>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script type="module">
  import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
  import { getAuth, onAuthStateChanged, signOut } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-auth.js";
  import { getFirestore, collection, getDocs, addDoc, doc, getDoc, updateDoc, increment, serverTimestamp, query, orderBy }
    from "https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js";

  const firebaseConfig = {
    apiKey:"AIzaSyAIBQseS7GTzddBODZcLm-iD_ol79rL6PA",authDomain:"cobold-b0e8d.firebaseapp.com",
    projectId:"cobold-b0e8d",storageBucket:"cobold-b0e8d.firebasestorage.app",
    messagingSenderId:"317072309656",appId:"1:317072309656:web:803003d311f119e437bfed"
  };
  const app=initializeApp(firebaseConfig), auth=getAuth(app), db=getFirestore(app);
  let currentUser=null, menuItems=[], ingredients=[], cart=[], orderType='dine-in', activeCat='Semua';
  let dataLoaded = false;

  onAuthStateChanged(auth, async(user)=>{
    if(!user){location.href="login.html";return;}
    const snap=await getDoc(doc(db,"users",user.uid));
    if(!snap.exists()){await signOut(auth);location.href="login.html";return;}
    const role=snap.data().role;
    if(role!=='kasir'&&role!=='admin'){location.href="login.html";return;}
    currentUser={uid:user.uid,name:snap.data().name||user.email,role};
    if(role==='admin') document.body.classList.add('is-admin');

    // Load both menu and ingredients first
    await Promise.all([loadMenu(), loadIngredients()]);
    dataLoaded = true;

    // Now render menu with ingredients data ready
    buildPills();
    renderMenu();

    document.getElementById('loadingOverlay').style.display='none';
  });

  async function loadMenu(){
    const snap=await getDocs(query(collection(db,"menu"),orderBy("category")));
    menuItems=snap.docs.map(d=>({id:d.id,...d.data()})).filter(m=>m.available!==false);
  }

  async function loadIngredients(){
    const snap=await getDocs(query(collection(db,"ingredients"),orderBy("category")));
    ingredients=snap.docs.map(d=>({id:d.id,...d.data()}));
  }

  function buildPills(){
    const cats=['Semua',...new Set(menuItems.map(m=>m.category).filter(Boolean))];
    document.getElementById('catPills').innerHTML=cats.map(c=>
      `<button class="cat-pill${c===activeCat?' active':''}" onclick="setCat('${c}')">${c}</button>`
    ).join('');
  }
  window.setCat=function(c){activeCat=c;document.querySelectorAll('.cat-pill').forEach(b=>b.classList.toggle('active',b.textContent===c));renderMenu();};

  function canMakeMenu(menuId){
    const m=menuItems.find(x=>x.id===menuId);
    if(!m||!m.recipe||!m.recipe.length) return true;
    for(const r of m.recipe){
      if(!r.ingredientId||!r.amount) continue;
      const ing=ingredients.find(i=>i.id===r.ingredientId);
      if(!ing) return false;
      if(ing.stock < r.amount) return false;
    }
    return true;
  }

  window.renderMenu=function(){
    if(!dataLoaded){
      document.getElementById('menuGrid').innerHTML='<div class="menu-empty">Memuat data...</div>';
      return;
    }

    const q=document.getElementById('searchInput').value.toLowerCase();
    const grid=document.getElementById('menuGrid');
    const list=menuItems.filter(m=>(activeCat==='Semua'||m.category===activeCat)&&(!q||m.name.toLowerCase().includes(q)));
    grid.innerHTML=list.length?list.map(m=>{
      const canMake=canMakeMenu(m.id);
      const disabledClass=canMake?'':' disabled';
      const onclick=canMake?`onclick="addToCart('${m.id}')"`:'';
      const stockText=canMake?'':'<div class="menu-card-stock low"><i class="fa-solid fa-circle-xmark"></i> Stok habis</div>';
      return`<div class="menu-card${disabledClass}" ${onclick}>
        <div class="menu-card-cat">${m.category||''}</div>
        <div class="menu-card-name">${m.name}</div>
        <div class="menu-card-price">Rp ${(m.price||0).toLocaleString('id')}</div>
        ${stockText}
      </div>`;
    }).join(''):`<div class="menu-empty">Menu tidak ditemukan.</div>`;
  };

  window.addToCart=function(id){
    const item=menuItems.find(m=>m.id===id); if(!item)return;
    const ex=cart.find(c=>c.id===id); if(ex)ex.qty++; else cart.push({id,name:item.name,price:item.price,qty:1});
    renderCart(); showToast('+ '+item.name,'success');
  };
  window.changeQty=function(id,d){
    const i=cart.findIndex(c=>c.id===id); if(i < 0)return;
    cart[i].qty+=d; if(cart[i].qty<=0)cart.splice(i,1); renderCart();
  };
  window.clearCart=function(){cart=[];renderCart();};

  function renderCart(){
    const total=cart.reduce((s,c)=>s+c.price*c.qty,0);
    document.getElementById('totalValue').textContent='Rp '+total.toLocaleString('id');
    document.getElementById('btnPay').disabled=cart.length===0;
    document.getElementById('orderItems').innerHTML=cart.length
      ?cart.map(c=>`<div class="order-item">
          <div class="oi-info"><div class="oi-name">${c.name}</div><div class="oi-price">Rp ${(c.price*c.qty).toLocaleString('id')}</div></div>
          <div class="qty-ctrl">
            <button class="qty-btn" onclick="changeQty('${c.id}',-1)">−</button>
            <span class="qty-num">${c.qty}</span>
            <button class="qty-btn" onclick="changeQty('${c.id}',1)">+</button>
          </div></div>`).join('')
      :`<div class="order-empty">Pilih menu untuk memulai.</div>`;
    updateCartFloat();
  }

  window.setType=function(t){
    orderType=t;
    document.getElementById('btnDineIn').classList.toggle('active',t==='dine-in');
    document.getElementById('btnTakeaway').classList.toggle('active',t==='takeaway');
    document.getElementById('tableWrap').classList.toggle('show',t==='dine-in');
  };

  window.openConfirm=function(){
    if(!cart.length)return;
    const total=cart.reduce((s,c)=>s+c.price*c.qty,0);
    const tableNo=document.getElementById('tableNo').value;
    const notes=document.getElementById('orderNotes')?.value||'';

    // KASIR TIDAK LIHAT HPP/PROFIT - hanya total dan item
    document.getElementById('confirmItems').innerHTML=`
      ${cart.map(c=>`<div class="confirm-item"><span>${c.name} ×${c.qty}</span><span>Rp ${(c.price*c.qty).toLocaleString('id')}</span></div>`).join('')}
      <div class="confirm-item"><span>Tipe</span><span>${orderType==='dine-in'?`Dine-in (Meja ${tableNo||'—'})`:'Takeaway'}</span></div>
      ${notes?`<div class="confirm-item"><span>Catatan</span><span>${notes}</span></div>`:''}
      <div class="confirm-total"><span>Total</span><span>Rp ${total.toLocaleString('id')}</span></div>`;
    document.getElementById('confirmModal').classList.add('show');
  };
  window.closeConfirm=function(){document.getElementById('confirmModal').classList.remove('show');};

  // ── VALIDASI STOK ──
  async function validateStock(){
    const needed={};
    for(const ci of cart){
      const md=await getDoc(doc(db,"menu",ci.id));
      const recipe=(md.data()?.recipe)||[];
      for(const r of recipe){
        if(!r.ingredientId||!r.amount) continue;
        needed[r.ingredientId]=(needed[r.ingredientId]||0)+(r.amount*ci.qty);
      }
    }
    for(const [ingId,amount] of Object.entries(needed)){
      const ing=ingredients.find(i=>i.id===ingId);
      if(!ing) return {ok:false, msg:`Bahan tidak ditemukan di inventory`};
      if(ing.stock < amount){
        return {ok:false, msg:`Stok ${ing.name} tidak cukup (tersisa ${ing.stock} ${ing.unit}, butuh ${amount} ${ing.unit})`};
      }
    }
    return {ok:true};
  }

  window.submitOrder=async function(){
    // VALIDASI STOK SEBELUM SUBMIT
    const stockCheck=await validateStock();
    if(!stockCheck.ok){
      showToast(stockCheck.msg,'error');
      closeConfirm();
      return;
    }

    const btn=document.getElementById('btnConfirm');
    btn.disabled=true;btn.textContent='Menyimpan...';
    try{
      const total=cart.reduce((s,c)=>s+c.price*c.qty,0);
      const tableNo=document.getElementById('tableNo').value;
      const notes=document.getElementById('orderNotes')?.value||'';

      // HPP & profit dihitung dan disimpan ke Firestore (untuk laporan admin)
      // tapi TIDAK DITAMPILKAN ke kasir
      let totalHPP = 0;
      const orderItems = cart.map(c=>{
        const m = menuItems.find(x => x.id === c.id);
        const itemHPP = m && m.hpp ? m.hpp.total : 0;
        totalHPP += itemHPP * c.qty;
        return {id:c.id,name:c.name,price:c.price,qty:c.qty};
      });

      await addDoc(collection(db,"orders"),{
        items:orderItems,
        total,
        hpp:totalHPP,           // ← disimpan untuk admin (hidden dari kasir)
        profit:total-totalHPP,   // ← disimpan untuk admin (hidden dari kasir)
        type:orderType,tableNo:orderType==='dine-in'?tableNo:null,
        notes:notes||null,status:"pending",
        kasirUid:currentUser.uid,kasirName:currentUser.name,createdAt:serverTimestamp()
      });

      for(const ci of cart){
        const md=await getDoc(doc(db,"menu",ci.id));
        for(const r of(md.data()?.recipe||[])){
          if(!r.ingredientId||!r.amount)continue;
          await updateDoc(doc(db,"ingredients",r.ingredientId),{stock:increment(-(r.amount*ci.qty))});
          const ig=await getDoc(doc(db,"ingredients",r.ingredientId));
          await addDoc(collection(db,"stockLogs"),{ingredientId:r.ingredientId,ingredientName:ig.data()?.name||'',unit:ig.data()?.unit||'',change:-(r.amount*ci.qty),note:`Order: ${ci.name} ×${ci.qty}`,byName:currentUser.name,createdAt:serverTimestamp()});
        }
      }
      // Refresh ingredients setelah decrement untuk update UI
      await loadIngredients(); renderMenu();
      closeConfirm(); clearCart();
      document.getElementById('tableNo').value='';
      if(document.getElementById('orderNotes')) document.getElementById('orderNotes').value='';
      showToast('✓ Pesanan berhasil disimpan!','success');
    }catch(e){showToast('Gagal: '+e.message,'error');}
    btn.disabled=false;btn.textContent='Konfirmasi';
  };

  function showToast(msg,type=''){
    const t=document.getElementById('toast');
    t.textContent=msg;t.className=`toast ${type} show`;
    setTimeout(()=>t.classList.remove('show'),2200);
  }
  document.getElementById('btnLogout').addEventListener('click',()=>signOut(auth).then(()=>location.href="login.html"));

  // ── MOBILE TAB SWITCH ──
  window.switchTab = function(tab) {
    const menuPanel = document.getElementById('menuPanel');
    const orderPanel = document.getElementById('orderPanel');
    const tabMenu = document.getElementById('tabMenu');
    const tabOrder = document.getElementById('tabOrder');
    const cartFloat = document.getElementById('cartFloat');

    if (tab === 'menu') {
      menuPanel.classList.add('active');
      orderPanel.classList.remove('active');
      tabMenu.classList.add('active');
      tabOrder.classList.remove('active');
      if (cart.length > 0) cartFloat.classList.remove('hidden');
    } else {
      menuPanel.classList.remove('active');
      orderPanel.classList.add('active');
      tabMenu.classList.remove('active');
      tabOrder.classList.add('active');
      cartFloat.classList.add('hidden');
    }
  };

  function updateCartFloat() {
    const total = cart.reduce((s, c) => s + c.price * c.qty, 0);
    const badge = document.getElementById('tabBadge');
    const cartFloat = document.getElementById('cartFloat');
    const cartFloatTotal = document.getElementById('cartFloatTotal');

    if (cart.length > 0) {
      badge.style.display = 'inline-flex';
      badge.textContent = cart.reduce((s, c) => s + c.qty, 0);
      cartFloat.classList.remove('hidden');
      cartFloatTotal.textContent = 'Rp ' + total.toLocaleString('id');
    } else {
      badge.style.display = 'none';
      cartFloat.classList.add('hidden');
    }
  }
</script>
<script src="nav-scroll.js"></script>
</body>
</html>